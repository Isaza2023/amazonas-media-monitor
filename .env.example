# CONFIGURACIÓN GENERAL
DEBUG=False
PORT=8000
HOST=127.0.0.1

# BASE DE DATOS (Por defecto SQLite local)
# Para cambiar a PostgreSQL: postgresql://usuario:contraseña@localhost:5432/bd_monitoreo
DATABASE_URL=sqlite:///C:/windows/Temp/amazonas_media_monitor/database/media_monitor.db

# LLAVES DE API DE REDES SOCIALES (Opcionales - Dejar vacías para usar simulación/RSS)
YOUTUBE_API_KEY=your_youtube_api_key_here
X_BEARER_TOKEN=your_x_bearer_token_here
FACEBOOK_ACCESS_TOKEN=your_facebook_token_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here
